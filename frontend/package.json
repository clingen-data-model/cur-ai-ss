{
  "name": "caa-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 8501",
    "prebuild": "../bin/generate-api-spec && pnpm api:generate",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "api:generate": "openapi-ts --input ./api-spec.json --output ./src/api/generated --client @hey-api/client-fetch"
  },
  "dependencies": {
