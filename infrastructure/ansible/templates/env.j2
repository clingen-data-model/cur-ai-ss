# Curator environment variables
# Generated by Ansible - do not edit manually on the VM
#
# This file contains sensitive credentials and should not be committed to git.

# CAA configuration
CAA_ROOT="/var/{{ caa_user }}"

# OpenAI configuration
OPENAI_API_KEY="{{ openai_api_key_content.stdout }}"
NCBI_API_KEY="{{ ncbi_api_key_content.stdout }}"
NCBI_EMAIL="{{ ncbi_email_content.stdout }}"

# CORS configuration
CORS_ALLOWED_ORIGINS="https://{{ domain }},http://localhost:8501"

# Auth / JWT configuration
JWT_SECRET_KEY="{{ auth_secrets.JWT_SECRET_KEY }}"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES="1440"

# SMTP configuration (registration / activation emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="{{ auth_secrets.SMTP_USER }}"
SMTP_PASSWORD="{{ auth_secrets.SMTP_PASSWORD }}"
SMTP_FROM="{{ auth_secrets.SMTP_FROM }}"
